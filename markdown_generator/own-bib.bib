@ARTICLE{2025A&A...693L...8L,
    abstract = {We report the detection of a core with a size of 282<SUB>−31</SUB><SUP>+34</SUP> pc in the center of Milky Way dark matter halo at the 68% confidence level. It was detected using the microlensing event-rate sky map data from the optical gravitational lensing experiment (OGLE) survey. We applied the spatial information of the microlensing sky map and modeled it with the detailed Milky Way dark matter halo core-cusp profile, and with the fraction of dark matter in the form of mini dark matter structure (MDMS; f<SUB>MDMS</SUB> = Ω<SUB>MDMS</SUB>/Ω<SUB>DM</SUB>) such as a primordial black hole, Earth-mass subhalos, or floating planets. This sky map can simultaneously constrain f<SUB>MDMS</SUB> and the core size without a strong degeneracy while fully considering the mass function of Milky Way stellar components from the bulge and disk.},
       author = {{Lin}, S. and {Luo}, W. and {Cai}, Y.~F. and {Guo}, Q. and {Wei}, L. and {Wang}, B. and {Li}, Qinxun and {Su}, C. and {Rodriguez}, A.},
        title = "{The density profile of Milky Way dark matter halo constrained from the OGLE microlensing sky map}",
      journal = {\aap},
     keywords = {contributing},
         year = 2025,
        month = jan,
       volume = {693},
          eid = {L8},
        pages = {L8},
          doi = {10.1051/0004-6361/202452408},
       adsurl = {https://ui.adsabs.harvard.edu/abs/2025A&A...693L...8L},
      adsnote = {Provided by the SAO/NASA Astrophysics Data System}
}
